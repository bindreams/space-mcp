# Space authentication token (personal or application)
# Create personal token at: https://jetbrains.team/m/me/authentication?tab=PermanentTokens
# Create application token at: Space Admin > Applications > [your-app] > Authentication > Permanent Tokens
SPACE_TOKEN=

# Patronus API URL (optional, defaults to https://patronus.labs.jb.gg)
PATRONUS_URL=
